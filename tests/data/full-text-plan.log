-- Task /Match and Find Duplicates/Redevabilite/Notify referencing that my SDPK has changed/Notify Referencing MI AssocieInterloCoordRede that my Golden Id has changed

update MI_ASSOCIE_INTERLO_COORD_RED as T
set
B_PENDINGACTIONS = 'HANDLE_DATA_CHANGE',
B_BATCHID = 61579,
F_REDEVABILITE = S.F_REDEVABILITE
from (
select
distinct
REFING.B_PUBID,
REFING.B_SOURCEID,
REFED.REDEVABILITE_ID F_REDEVABILITE
from
MI_REDEVABILITE REFED
inner join MI_REDEVABILITE REFED2
on (
REFED.REDEVABILITE_ID = REFED2.REDEVABILITE_ID
and REFED2.B_BATCHID = 61579
and REFED.B_CLASSNAME = 'Redevabilite'
and (REFED2.B_OLDSDPK is null or REFED2.B_OLDSDPK <> REFED2.REDEVABILITE_ID)
)
inner join MI_ASSOCIE_INTERLO_COORD_RED REFING
on (
REFED.B_PUBID = REFING.FP_REDEVABILITE
and REFED.B_SOURCEID = REFING.FS_REDEVABILITE
)
where
REFING.B_BATCHID <= 61579
and REFED.B_BATCHID = 61579
and REFED.B_CLASSNAME = 'Redevabilite'
and REFING.B_CLASSNAME in (
'AssocieInterloCoordRede'
)
) as S
where
T.B_PUBID = S.B_PUBID and T.B_SOURCEID = S.B_SOURCEID

