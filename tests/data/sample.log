USING t2b
ON (t1.i=t2b.i)
WHEN NOT MATCHED AND t2b.i >= :MINIMUM THEN
  INSERT VALUES (t2b.i, null, t2b.filler)
WHEN MATCHED AND t2b.i < :MINIMUM THEN
  DELETE
WHEN MATCHED THEN
  UPDATE SET filler=t2b.filler, x=null ;

